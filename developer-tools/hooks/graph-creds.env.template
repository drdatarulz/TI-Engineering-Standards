# Claude Code notification credentials
# Copy to ~/.claude/hooks/graph-creds.env and fill in values
# DO NOT commit the filled-in version — it contains secrets

# General
NOTIFY_ENABLED=true
NOTIFY_DELAY_SECONDS=120
NOTIFY_METHOD=teams

# Teams webhook (required if NOTIFY_METHOD=teams)
TEAMS_WEBHOOK_URL=

# Microsoft Graph email (required if NOTIFY_METHOD=email)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
NOTIFY_FROM=
NOTIFY_TO=
